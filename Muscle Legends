local function SaveConfig()
    pcall(function() writefile("ML_Expert_Config.json", HttpService:JSONEncode(Config)) end)
end

local function getRockInstance(configName)
    local data = rockData[configName]
    if not data then return nil end
    local folder = workspace:FindFirstChild("machinesFolder")
    if not folder then return nil end
    local found = {}
    for _, v in ipairs(folder:GetChildren()) do
        if v.Name == data.name then table.insert(found, v) end
    end
    return found[data.idx]
end

local function getPunch()
    return player.Backpack:FindFirstChild("Punch") or (player.Character and player.Character:FindFirstChild("Punch"))
end

local function handleGlitchCleanup(method, callback)
    local p = getPunch()
    if p and p:FindFirstChild("attackTime") then p.attackTime.Value = 0.35 end
    
    if method == "Teleport" then
        if states.preGlitchPos and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = states.preGlitchPos
        end
        if callback then callback() end
    elseif method == "NonTeleport" then
        states.isTransitioning = true
        task.spawn(function()
            task.wait(1)
            for rock, data in pairs(rockCache) do
                if rock and rock.Parent then
                    rock.Size = data.Size
                    rock.CanCollide = data.CanCollide
                    rock.CFrame = data.CFrame
                end
            end
            table.clear(rockCache)
            states.isTransitioning = false
            if callback then callback() end
        end)
    else
        if callback then callback() end
    end
end

local function formatNum(n)
    local num = tonumber(n)
    if not num then return tostring(n) end
    if states.withoutFormatNum then return tostring(num) end
    local function trunc(val) return math.floor(val * 100) / 100 end
    if num >= 1e18 then return string.format("%.2fQi", trunc(num / 1e18))
    elseif num >= 1e15 then return string.format("%.2fQa", trunc(num / 1e15))
    elseif num >= 1e12 then return string.format("%.2fT", trunc(num / 1e12))
    elseif num >= 1e9 then return string.format("%.2fB", trunc(num / 1e9))
    elseif num >= 1e6 then return string.format("%.2fM", trunc(num / 1e6))
    elseif num >= 1e3 then return string.format("%.2fK", trunc(num / 1e3))
    else return tostring(num) end
end

local function makeDraggable(gui)
	local dragging, dragInput, dragStart, startPos
	gui.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true; dragStart = input.Position; startPos = gui.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
		end
	end)
	gui.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end

