local SetToggle = {}
local function createToggle(parent, text, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -10, 0, 30); btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45); btn.Text = text .. " [OFF]"; btn.TextColor3 = Color3.new(1, 1, 1)
    local state = false
    SetToggle[btn] = function(newState)
        state = newState
        btn.Text = text .. (state and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(45, 45, 45)
    end
    btn.MouseButton1Click:Connect(function() local ns = not state; if callback(ns) == false then ns = false end SetToggle[btn](ns) end)
    return btn
end

local function createDropdown(parent, text, options, multi, callback, checkStateFunc)
    local container = Instance.new("Frame", parent); container.Size = UDim2.new(1, -10, 0, 30); container.BackgroundTransparency = 1
    local header = Instance.new("TextButton", container); header.Size = UDim2.new(1, 0, 0, 30); header.BackgroundColor3 = Color3.fromRGB(50, 50, 50); header.Text = text .. " v"; header.TextColor3 = Color3.new(1, 1, 1)
    local list = Instance.new("ScrollingFrame", container); list.Position = UDim2.fromOffset(0, 30); list.Visible = false; list.ZIndex = 10; list.BackgroundColor3 = Color3.fromRGB(40, 40, 40); list.ScrollBarThickness = 4
    header.MouseButton1Click:Connect(function() list.Visible = not list.Visible; local lh = math.min(#options * 25, 150); container.Size = list.Visible and UDim2.new(1, -10, 0, lh + 30) or UDim2.new(1, -10, 0, 30); list.Size = UDim2.new(1, 0, 0, lh); list.CanvasSize = UDim2.new(0, 0, 0, #options * 25) end)
    local function refresh(newOpts)
        if newOpts then options = newOpts end
        for _, v in ipairs(list:GetChildren()) do v:Destroy() end
        for i, opt in ipairs(options) do
            local o = Instance.new("TextButton", list); o.Size = UDim2.new(1, 0, 0, 25); o.Position = UDim2.fromOffset(0, (i-1)*25); o.Text = tostring(opt); o.TextColor3 = Color3.new(1, 1, 1); o.ZIndex = 11; o.BackgroundColor3 = (multi and checkStateFunc and checkStateFunc(opt)) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
            o.MouseButton1Click:Connect(function() if not multi then header.Text = tostring(opt) .. " v"; list.Visible = false; container.Size = UDim2.new(1, -10, 0, 30); callback(opt) else local ns = callback(opt); o.BackgroundColor3 = ns and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60) end end)
        end
    end
    refresh(); return { refresh = refresh, setHeaderText = function(txt) header.Text = txt end }
end

