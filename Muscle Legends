table.insert(getgenv().ML_Expert_Loops, task.spawn(function()
    while true do
        local delayTime = states.lessLag and 0.1 or 0
        if states.lessLag then task.wait(delayTime) else RunService.Heartbeat:Wait() end

        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
        local root = char.HumanoidRootPart
        local hum = char:FindFirstChild("Humanoid")

        -- AUTO GLITCH LOGIC
        if states.autoGlitch and states.selectedRock and not states.isTransitioning then
            local rockModel = getRockInstance(states.selectedRock)
            local rockPart = rockModel and (rockModel:FindFirstChild("Rock") or rockModel:FindFirstChildWhichIsA("BasePart"))
            
            if rockPart then
                local punch = getPunch()
                
                if states.selectedMethod == "Teleport" then
                    -- TELEPORT METHOD
                    if punch then
                        punch.Parent = char
                        if punch:FindFirstChild("attackTime") then punch.attackTime.Value = 0 end
                        punch:Activate()
                    end
                    -- Position at edge
                    local offset = (rockPart.Size.Z / 2) + 2
                    root.CFrame = CFrame.lookAt((rockPart.CFrame * CFrame.new(0, 0, offset)).Position, rockPart.Position)
                    
                    -- Only allow Punch tool unless Auto Glitch Training is on
                    if not states.autoGlitchTrain then
                        for _, t in ipairs(char:GetChildren()) do
                            if t:IsA("Tool") and t.Name ~= "Punch" then t.Parent = player.Backpack end
                        end
                    end
                elseif states.selectedMethod == "NonTeleport" then
                    -- NON-TELEPORT METHOD
                    if not rockCache[rockPart] then
                        rockCache[rockPart] = {Size = rockPart.Size, CanCollide = rockPart.CanCollide, CFrame = rockPart.CFrame}
                    end
                    
                    rockPart.CanCollide = false
                    rockPart.Size = Vector3.new(1, 1, 1)
                    
                    local hand = toggleHand and "LeftHand" or "RightHand"
                    local target = char:FindFirstChild(hand) or char:FindFirstChild("Right Arm")
                    if target then rockPart.CFrame = target.CFrame end
                    toggleHand = not toggleHand
                    
                    -- Multi-Remote Fire
                    player.muscleEvent:FireServer("punch", "leftHand")
                    player.muscleEvent:FireServer("punch", "rightHand")
                    
                    -- Multi-Tool Equip check
                    if not states.autoGlitchTrain then
                        -- Keep only Punch
                        for _, t in ipairs(char:GetChildren()) do
                            if t:IsA("Tool") and t.Name ~= "Punch" then t.Parent = player.Backpack end
                        end
                    end
                end

                -- Training Logic
                if states.autoGlitchTrain then
                    for _, t in ipairs(char:GetChildren()) do
                        if t:IsA("Tool") then 
                            t:Activate() 
                            -- Glue Weight to Hand
                            if t.Name == "Weight" and t:FindFirstChild("Handle") then
                                local rHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
                                if rHand then
                                    t.Handle.CFrame = rHand.CFrame
                                end
                            end
                        end
                    end
                end
            end
        end

        -- AUTO EQUIP FIX
        if states.autoEquip and not states.autoGlitch then
            local targetTool = player.Backpack:FindFirstChild("Punch") or player.Backpack:FindFirstChild("Weight")
            if targetTool and not char:FindFirstChild(targetTool.Name) then
                hum:EquipTool(targetTool)
            end
        end
        
        -- AUTO REBIRTH
        if states.autoRebirthInf then
            ReplicatedStorage.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
        end
        
        -- AUTO LIFT NO ANIM
        if states.autoLiftNoAnim then
            player.muscleEvent:FireServer("rep")
        end
    end
end))

